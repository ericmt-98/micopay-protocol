<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!--
        Debug-build-only override (lives in src/debug/, never merged into
        release builds — see app/src/main/res/xml/network_security_config.xml
        for the production config, which keeps cleartextTrafficPermitted="false").

        Permits plain HTTP only to loopback hosts, so a debug APK can talk to
        a backend running on the developer's machine (reached via
        `adb reverse tcp:<port> tcp:<port>` over USB, or 10.0.2.2 on the
        Android emulator) without weakening the production network policy.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

</network-security-config>
